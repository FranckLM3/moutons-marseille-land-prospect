# ── Secrets ───────────────────────────────────────────────────────────────
.env

# ── Généré (ne pas versionner, contient la clé ORS injectée) ──────────────
docs/index.html

# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
menv/
dist/
build/

# ── Données volumineuses (non versionnées) ────────────────────────────────
data/*

# ── GeoJSON bruts (non versionnés) ───────────────────────────────────────
*.geojson
# Exception : fichiers communes statiques versionnés dans docs/
!docs/data/communes/*.geojson
!docs/data/communes/index.json

# ── Formats carto ─────────────────────────────────────────────────────────
*.mbtiles
*.gpkg
*.7z

# ── Scripts shell locaux ──────────────────────────────────────────────────
scripts/*.sh

# ── IDE / OS ──────────────────────────────────────────────────────────────
.DS_Store
.vscode/settings.json
*.swp
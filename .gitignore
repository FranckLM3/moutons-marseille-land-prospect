# ── Secrets ───────────────────────────────────────────────────────────────
.env

# ── Généré (ne pas versionner, contient la clé ORS injectée) ──────────────
docs/index.html

# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
menv/
dist/
build/

# ── Données volumineuses (non versionnées) ────────────────────────────────
data/*

# ── GeoJSON bruts (sauf le fichier de sortie GitHub Pages) ────────────────
*.geojson
!docs/pasture_zones.geojson

# ── Formats carto ─────────────────────────────────────────────────────────
*.mbtiles
*.gpkg

# ── Scripts shell locaux ──────────────────────────────────────────────────
scripts/*.sh

# ── Anciens dossiers devenus obsolètes ────────────────────────────────────
front/
test/

# ── IDE / OS ──────────────────────────────────────────────────────────────
.DS_Store
.vscode/settings.json
*.swp